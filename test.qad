<?xml version="1.0" encoding="UTF-8" ?>

<quartz-document spec="0.1">
    <size width="1920" height="1080"/>
    <framerate fps="24"/>
    <background color="#FFFFFF"/>
    <library group="library">
        <folder name="dummy">
            <symbol type="drawing" name="infold">
                <points lc="[(0,0),(200,200)]"/>
                <stroke points="[0,1]" color="#000000" thickness="10px"/>
            </symbol>
        </folder>
    </library>
    <library group="scene">
        <symbol name="scene1" type="scene">
            <layer name="test">
                <frame length="1">
                    <instance path="library:dummy/infold"/>
                </frame>
            </layer>
        </symbol>
    </library>
</quartz-document>